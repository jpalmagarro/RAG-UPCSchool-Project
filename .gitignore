__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.python-version

# Virtual environments
.venv/
venv/
env/
ENV/
.Python

# IDEs
.vscode/
.idea/
.cursor/

# Jupyter
.ipynb_checkpoints/
notebooks/chroma_db/

# Databases
*.sqlite3
*.db

# Data and artifacts
data/
build/
dist/
*.egg-info/

# Logs
logs/
*.log

# OS files
.DS_Store
Thumbs.db

# Secrets and environment
.env
.env.*
!.env.example
secrets.*
credentials.*

# Misc
*.pem
*.key
*.coverage
.coverage
.conda/

# Generated docs (not the docs/ folder itself)
docs/architecture/cosora_architecture_final.md
docs/architecture/implementation_plan.md
docs/experiments/*.md


