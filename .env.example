# Copy this file to .env and fill in your values
# .env is gitignored — never commit it

# OpenAI
OPENAI_API_KEY=sk-...

# App Password (for Streamlit UI)
APP_PASSWORD=tribunal2026

# Embedding model (optional override)
EMBEDDING_MODEL=BSC-LT/MrBERT-es

# RAG mode: v1 | v2 | v2_table (v2_table usa colección cosora_actas_e5_v2)
RAG_MODE=v2

# ChromaDB
CHROMA_PATH=./data/chroma_db
CHROMA_COLLECTION=

# RAG v2 retrieval (BM25Log1 + pool amplio)
RETRIEVAL_K=50
V1_RETRIEVAL_K=5
TOP_N=5
RRF_K=60
RRF_MIN_SCORE=0.01
BM25_PATH=
EMBED_MODEL_NAME=intfloat/multilingual-e5-base
HF_MODEL_PATH=./hf_model

# GCP Storage Bucket (Para automatizar descargas de DB)
GCP_BUCKET_NAME=rag-actas-db-bucket

# Google Drive API (Para descarga directa de actas .docx)
DRIVE_FOLDER_ID=1XyZ_abc123DEF456

# Neo4j Aura (Graph RAG con Cypher — notebooks/experiments/neo4j_graph_rag.ipynb)
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-password-here
NEO4J_DATABASE=neo4j
